# === Required: GCP Configuration ===
# Local dev: set path to service account JSON key
# Cloud Run: leave empty (uses built-in service account)
GOOGLE_APPLICATION_CREDENTIALS=

GCP_PROJECT_ID=
GCS_BUCKET_NAME=
BIGQUERY_DATASET=risksense

# === Required for live weather data (falls back to mock if unset) ===
OPENWEATHERMAP_API_KEY=

# === Optional: AI risk explanations via Gemini (falls back to rule-based) ===
GEMINI_API_KEY=
